# Copia este archivo a .env y completa los valores.
#   cp .env.example .env

# Clave de la API de Google Gemini (fallback de IA para extracción de billing y chat)
GEMINI_API_KEY=your_gemini_api_key_here

# Secreto para firmar los JWT de sesión (usa una cadena larga y aleatoria)
JWT_SECRET=your_long_random_secret_here

# Administrador inicial sembrado en la base de datos vacía en el primer arranque
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme
